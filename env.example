# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES (Vite - exposed as VITE_*)
# ============================================================================
# These are accessible in client code via import.meta.env.VITE_*

# API Configuration
# For Vercel: Use the Render backend URL
# For local dev: Use http://localhost:5001 or leave blank (defaults to /api proxy)
VITE_API_URL=https://micro-internship-api.onrender.com

# Firebase Configuration (REQUIRED)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AI Internship Matching (Optional - Groq or OpenAI)
# Groq (recommended, free tier):
VITE_AI_API_KEY=gsk_YOUR_GROQ_API_KEY
VITE_AI_API_URL=https://api.groq.com/openai/v1/chat/completions
VITE_AI_MODEL=llama-3.1-8b-instant

# OpenAI (alternative):
# VITE_AI_API_URL=https://api.openai.com/v1/chat/completions
# VITE_AI_MODEL=gpt-4o-mini

# ============================================================================
# BACKEND ENVIRONMENT VARIABLES (Node.js/Express - server only)
# ============================================================================
# These are NOT exposed to the frontend. Set on Render via Dashboard.

# Port Configuration
# On Render: Leave unset (Render assigns PORT automatically)
# Local dev: Optional, defaults to 5001
PORT=5001

# CORS Configuration (REQUIRED for Vercel deployment) ⚠️ CRITICAL ⚠️
# Your frontend Vercel domain must be included here
# Format: comma-separated list
# Example: https://my-app.vercel.app,https://my-app-staging.vercel.app,http://localhost:3000
# The *.vercel.app wildcard is automatically included by the backend
CORS_ORIGINS=https://micro-internship.vercel.app,http://localhost:3000

# Firebase Admin SDK (REQUIRED for token verification)
# Option 1: For Render deployment - encode serviceAccountKey.json as Base64:
#   cat serviceAccountKey.json | base64 | pbcopy
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option 2: Provide project ID and file path
FIREBASE_PROJECT_ID=micro-internship-portal
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# AI Internship Matching (Optional - server-side configuration)
# If not set, backend falls back to VITE_* prefixed versions
AI_API_KEY=gsk_YOUR_GROQ_API_KEY
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_MODEL=llama-3.1-8b-instant

# Rate Limiting
# Max requests per 15 minutes per IP
API_RATE_LIMIT=300

# Environment
NODE_ENV=production

# ============================================================================
# DEPLOYMENT INSTRUCTIONS
# ============================================================================
# 
# VERCEL (Frontend):
# 1. Create .env.production.local with VITE_* variables
# 2. Or set them in Vercel Dashboard → Settings → Environment Variables
# 3. Required: VITE_API_URL, VITE_FIREBASE_*
# 
# RENDER (Backend):
# 1. Go to Dashboard → Select API service → Environment
# 2. Add all server variables (CORS_ORIGINS, FIREBASE_*, AI_*)
# 3. For Firebase: Encode serviceAccountKey.json to Base64
#    Then set FIREBASE_SERVICE_ACCOUNT_JSON to the Base64 string
# 4. Deploy will auto-read CORS_ORIGINS and other env vars
# ============================================================================
